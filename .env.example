# Docker images and container names
UNIEMU_IMAGE=uniemu:local
UNIEMU_CONTAINER_NAME=uniemu
UNIEMU_DISPATCHER_MOCK_IMAGE=uniemu-dispatcher-mock:local
UNIEMU_DISPATCHER_MOCK_CONTAINER_NAME=uniemu-dispatcher-mock
BUILD_CONFIGURATION=Release

# Public ports
UNIEMU_PORT=5083
UNIEMU_DISPATCHER_MOCK_PORT=8080

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
UNIEMU_ALLOWED_HOSTS=*

# Backend database
UNIEMU_DB_CONNECTION=Data Source=/app/data/uniemu.db

# Backend application settings
UNIEMU_TIME_ZONE=Europe/Moscow
UNIEMU_CULTURE=ru-RU
UNIEMU_DISABLE_RUNTIME=false
UNIEMU_SKIP_STARTUP_DATABASE=false
UNIEMU_SEED_DATA=false
UNIEMU_DISABLE_STATIC_ASSETS=false
UNIEMU_ENABLE_STATIC_ASSET_COMPRESSION=true
UNIEMU_ENABLE_STATIC_ASSET_CACHING=true
UNIEMU_DISPATCHER_BLOCK_CHECK_INTERVAL_SECONDS=5

# Backend REST catalog used by scripts
UNIEMU_REST_DEFAULT_CLIENT_BASE_URL=https://external-system.local
UNIEMU_REST_DEFAULT_CLIENT_TIMEOUT_SECONDS=5
UNIEMU_REST_OPERATION_GET_WORKER_BY_ID_METHOD=GET
UNIEMU_REST_OPERATION_GET_WORKER_BY_ID_PATH=/api/workers/{workerId}
UNIEMU_REST_OPERATION_GET_WORKER_BY_ID_RESPONSE=Worker
UNIEMU_REST_OPERATION_GET_ACTIVE_WORKER_METHOD=GET
UNIEMU_REST_OPERATION_GET_ACTIVE_WORKER_PATH=/api/workers/active
UNIEMU_REST_OPERATION_GET_ACTIVE_WORKER_RESPONSE=Worker
UNIEMU_REST_OPERATION_REGISTER_WORKER_METHOD=POST
UNIEMU_REST_OPERATION_REGISTER_WORKER_PATH=/api/workers/{workerId}/register
UNIEMU_REST_OPERATION_REGISTER_WORKER_RESPONSE=

# Backend logging
UNIEMU_LOG_LEVEL=Information
UNIEMU_LOG_LEVEL_MICROSOFT=Warning
UNIEMU_LOG_LEVEL_MICROSOFT_ASPNETCORE=Warning
UNIEMU_LOG_LEVEL_MICROSOFT_ASPNETCORE_HOSTING=Warning
UNIEMU_LOG_LEVEL_MICROSOFT_ASPNETCORE_ROUTING=Warning
UNIEMU_LOG_LEVEL_MICROSOFT_ASPNETCORE_MVC_INFRASTRUCTURE=Warning
UNIEMU_LOG_LEVEL_TELEMETRY_PACKET_SENDER=Warning
UNIEMU_LOG_LEVEL_QUARTZ=Information
UNIEMU_LOG_FILE_PATH=Logs/uniemu-.log
UNIEMU_LOG_FILE_RETAINED_COUNT=14
UNIEMU_LOG_FILE_SIZE_LIMIT_BYTES=10485760

# Frontend Vite settings
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:5083
VITE_PERSIST_STORE=false
